{
  "_readme": "All dictionaries used by the pipeline (run_pipeline.py / pipeline/*.py). Fields starting with '_' are documentation only. Term syntax: lowercase; a trailing '*' matches any word ending (e.g. 'customiz*' matches customize/customization); spaces in a phrase also match hyphens (e.g. 'in house' matches 'in-house') and tolerate one intercalated adverb from just/recently/finally (e.g. 'we bought' also matches 'we just bought').",

  "queries": [
    "build OR buy",
    "\"build vs buy\" OR \"buy vs build\"",
    "\"built in-house\" OR \"build in-house\" OR \"developed in-house\" OR \"in-house tool\" OR \"in-house software\" OR \"in-house solution\" OR \"in-house system\" OR \"in-house platform\" OR \"custom-built\" OR \"custom-developed\" OR \"self-hosted\" OR \"rolled our own\" OR \"roll our own\" OR \"rolled my own\" OR \"roll my own\" OR \"developed internally\" OR \"developed my own\" OR \"develop my own\" OR \"build our own\" OR \"build my own\" OR \"vibe coded\" OR \"vibe coding\" OR \"diy solution\" OR \"diy tool\"",
    "\"built our own\" OR \"off the shelf\"",
    "\"off the shelf software\" OR \"vendor solution\" OR \"went with a vendor\" OR \"signed with a vendor\" OR \"bought a license\" OR \"purchased a license\" OR \"subscription service\" OR \"saas solution\" OR \"enterprise license\" OR \"licensing cost\" OR \"vendor tool\" OR \"third party software\" OR \"outsourced to a vendor\""
  ],
  "_queries_note": "The 5 queries cover generic build-vs-buy decision vocabulary. Discovery additionally screens every post against ONE derived query built at runtime from the patterns of every legal_specific provider in 'providers' below (single source of truth: edit the provider list and the screening filter follows; generic tools like chatgpt/aws are measured once a thread is collected but are too unspecific to drive discovery).",

  "gate": {
    "_rule": "Corpus tiering (title+body only). TIER 1 'decision threads': (strong decision phrase, OR weak decision verb together with a legaltech term) AND legal-domain evidence (legal term, OR legal-specific provider named). TIER 2 'discourse threads': no decision phrasing, but legal-domain evidence AND tech context (legaltech term or any provider) AND at least one study factor or provider mentioned - kept so factor talk without explicit decisions still counts. Everything else is excluded as off-topic. Report headline factor salience on tier 1; use tier 1+2 for the discourse-wide view and as robustness check.",
    "strong_phrases": [
      "build vs buy", "build or buy", "buy vs build", "buy or build", "build versus buy",
      "in house", "inhouse", "built our own", "build our own", "building our own",
      "built my own", "build my own", "build your own", "built in house",
      "vibe coding", "vibe coded", "vibecoding", "vibecoded",
      "self host", "self hosted", "selfhost", "selfhosted",
      "no code", "nocode", "low code", "lowcode",
      "from scratch", "license fee", "licensing cost", "enterprise license", "off the shelf"
    ],
    "weak_verbs": [
      "build", "building", "built", "buy", "buying", "bought", "purchase", "purchasing",
      "develop", "developing", "developed", "code", "coding", "coded", "automate", "automating",
      "roll out", "rolling out", "rolled out"
    ],
    "legaltech_terms": [
      "software", "tool", "tools", "app", "apps", "application", "platform", "system",
      "stack", "solution", "automation", "ai", "bot", "agent", "agents", "workflow",
      "database", "template", "templates", "integration", "api", "llm",
      "script", "chatbot", "intranet", "portal",
      "clm", "contract lifecycle", "document automation", "practice management software", "meta management",
      "vendor", "vendors", "saas", "procurement",
      "legal tech", "legaltech"
    ],
    "legal_terms": [
      "legal", "law firm", "lawyer", "lawyers", "attorney", "attorneys", "paralegal",
      "counsel", "compliance", "contract", "contracts", "litigation",
      "matter management", "ediscovery", "e discovery", "due diligence", "firm",
      "lawsuit", "plaintiff", "defendant", "regulatory"
    ]
  },

  "stance": {
    "_rule": "Threads with fewer than min_comments scraped comments are classified 'too_short' instead of 'unclear': there is not enough text for the hit counts to reach min_hits, so 'unclear' would conflate genuine ambiguity with plain lack of data.",
    "build_signals": [
      "build our own", "built our own", "building our own", "build my own", "built my own",
      "in house", "inhouse", "build internally", "built internally", "internal tool",
      "self host", "self hosted", "selfhost", "selfhosted",
      "diy", "from scratch", "vibe coding", "vibe coded", "vibecoding", "vibecoded",
      "custom build", "custom built",
      "we built", "i built", "we developed", "i developed", "develop ourselves",
      "we coded", "i coded",
      "rolled my own", "roll my own", "developed my own", "develop my own",
      "no code", "nocode", "low code", "lowcode", "own solution", "roll our own"
    ],
    "buy_signals": [
      "off the shelf", "vendor", "vendors", "saas", "license", "licence", "licensing",
      "subscription", "procurement", "purchase", "purchased", "demo", "demos",
      "pricing", "per seat", "sales team", "contract with", "signed with", "renewal",
      "implementation partner", "onboarding fee"
    ],
    "min_hits": 3,
    "dominance_ratio": 2.0,
    "min_comments": 3
  },

  "factors": {
    "_rule": "Salience = share of threads mentioning the factor (reported per tier); tone = mean VADER compound of sentences mentioning it. BEFORE freezing this list, the step-B cross-check was manually ran by me (Gina): high-frequency uncovered terms in term_discovery.csv were added and any missing factors.",
