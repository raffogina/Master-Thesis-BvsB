  "sentiment": {
    "_rule": "VADER compound of every sentence in TIER-1 threads that contains a direct subject-verb bigram - a decision_subjects pronoun followed by a decision_verbs word, tolerating one intervening adverb in between (pipeline/step3d_sentiment.py). Matching is sentence-scoped (split on . ! ?), never across the whole post/thread. This enforces real subject-verb adjacency: 'we bought Clio and regret it' counts ('we bought' bigram present) but 'I heard they migrated to X' does not (the word right before 'migrated' is 'they', not 'i'/'we' - no 'i migrated'/'we migrated' bigram exists). Captures the tone with which posters describe decisions they actually took; excludes hypotheticals, advice to third parties, and decisions attributed to someone else. Every qualifying sentence keeps its OWN tone score and stance tag (nothing is collapsed into a single number) - decision_tone_mean/n_decision_sentences in the output are a convenience summary only; the per-sentence detail is in the 'sentences' list of step3d_sentiment.json and in the flat decision_sentences.csv step4 builds from it (box-plot-ready: one row per decision sentence, group by 'stance').",
    "_ambiguity_rule": "Several decision_verbs double as everyday (non-software) phrasing - 'we dropped the case', 'we picked a jury', 'we settled on a court date' - which would otherwise get scored as if they were procurement decisions. Same fix as the ambiguous providers: a subject-verb bigram only counts as a decision sentence if the SAME sentence also contains a hit from gate.legaltech_terms or a recognized provider name (config providers.entries, patterns + ambiguous_patterns). This trades a little recall (a decision sentence that doesn't repeat a software noun/provider name, e.g. 'We bought it and never looked back' referring back to an earlier sentence) for much better precision, and tier-1 threads are already guaranteed legal+tech context elsewhere in the post.",
    "_stance_rule": "Per-sentence build/buy stance tag (pipeline/step3d_sentiment.py): a decision sentence is 'build' if it hits stance.build_signals, 'buy' if it hits stance.buy_signals, 'mixed' if both, else falls back to a tie-breaker for sentences the stance dictionaries don't cover (e.g. 'we chose Ironclad'): 'build' if the matched decision_verb is in unambiguous_build_verbs, 'buy' if it is in unambiguous_buy_verbs OR the sentence names any recognized provider (naming a specific commercial vendor is itself buy evidence - you cannot 'buy' a tool you built), else 'unclear'.",
    "decision_subjects": ["i", "we"],
    "decision_verbs": [
      "built", "bought", "purchased", "developed", "coded", "deployed",
      "migrated", "switched", "chose", "decided", "moved to", "went with",
      "implemented", "signed with", "adopted", "picked", "selected",
      "rolled out", "ended up", "opted for", "settled on", "upgraded to",
      "downgraded to", "ditched", "dropped", "canceled", "cancelled",
      "renewed", "stuck with",
      "procured", "licensed", "subscribed to", "built internally",
      "developed internally", "engineered", "custom built"
    ],
    "unambiguous_build_verbs": [
      "built", "developed", "coded", "engineered", "custom built",
      "built internally", "developed internally"
    ],
    "unambiguous_buy_verbs": [
      "bought", "purchased", "procured", "licensed", "subscribed to"
    ]
  },

