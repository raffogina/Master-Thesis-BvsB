{
  "_readme": "All dictionaries used by the pipeline (run_pipeline.py / pipeline/*.py). This file IS methodology: reproduce it in the thesis Annex and cite a source for every list you keep. Fields starting with '_' are documentation only. Term syntax: lowercase; a trailing '*' matches any word ending (e.g. 'customiz*' matches customize/customization); spaces in a phrase also match hyphens (e.g. 'in house' matches 'in-house') and tolerate one intercalated adverb from just/recently/finally (e.g. 'we bought' also matches 'we just bought').",

  "queries": [
    "build OR buy",
    "\"build vs buy\" OR \"buy vs build\"",
    "vendor OR \"in-house\" OR \"in house\"",
    "\"built our own\" OR \"off the shelf\""
  ],
  "_queries_note": "The 4 queries cover generic build-vs-buy decision vocabulary. Discovery additionally screens every post against ONE derived query built at runtime from the patterns of every legal_specific provider in 'providers' below (single source of truth: edit the provider list and the screening filter follows; generic tools like chatgpt/aws are measured once a thread is collected but are too unspecific to drive discovery). Provider-name screening was added on 2026-07-10 to close a recall gap found manually - a thread comparing Harvey/Claude/Legora/CoCounsel pricing did not surface under any of the 4 generic queries. The gate/tier filter in 'gate' below is unchanged - provider screening only widens discovery, it does not affect which threads are kept or how they are tiered.",

  "gate": {
    "_rule": "Corpus tiering (title+body only). TIER 1 'decision threads': (strong decision phrase, OR weak decision verb together with a software noun) AND legal-domain evidence (legal term, OR legal-specific provider named). TIER 2 'discourse threads': no decision phrasing, but legal-domain evidence AND tech context (software noun or any provider) AND at least one study factor or provider mentioned - kept so factor talk without explicit decisions still counts. Everything else is excluded as off-topic. Report headline factor salience on tier 1; use tier 1+2 for the discourse-wide view and as robustness check.",
    "strong_phrases": [
      "build vs buy", "build or buy", "buy vs build", "buy or build", "build versus buy",
      "in house", "inhouse", "built our own", "build our own", "building our own",
      "built my own", "build my own", "build your own", "built in house",
      "off the shelf", "vendor", "vendors", "saas", "procurement",
      "clm", "contract lifecycle", "document automation", "practice management software",
      "legal tech", "legaltech", "vibe coding", "vibe coded", "self host", "self hosted",
      "from scratch", "license fee", "licensing cost", "enterprise license"
    ],
    "weak_verbs": [
      "build", "building", "built", "buy", "buying", "bought", "purchase", "purchasing",
      "develop", "developing", "developed", "code", "coding", "coded", "automate", "automating"
    ],
    "software_nouns": [
      "software", "tool", "tools", "app", "apps", "application", "platform", "system",
      "stack", "solution", "automation", "ai", "bot", "agent", "agents", "workflow",
      "database", "template", "templates", "integration", "api", "llm", "gpt",
      "dashboard", "script", "chatbot", "intranet", "portal"
    ],
    "legal_terms": [
      "legal", "law firm", "lawyer", "lawyers", "attorney", "attorneys", "paralegal",
      "counsel", "compliance", "contract", "contracts", "clm", "litigation",
      "matter management", "ediscovery", "e discovery", "due diligence", "firm"
    ]
  },

  "stance": {
    "_rule": "Heuristic orientation of the discussion, NOT a verified decision. Verify a sample by hand in the manual_decision column (see README validation protocol).",
    "build_signals": [
      "build our own", "built our own", "building our own", "build my own", "built my own",
      "in house", "inhouse", "internally", "internal tool", "self host", "self hosted",
      "diy", "from scratch", "vibe coding", "vibe coded", "custom build", "custom built",
      "we built", "i built", "we developed", "i developed", "develop ourselves",
      "no code", "low code", "own solution", "roll our own"
    ],
    "buy_signals": [
      "off the shelf", "vendor", "vendors", "saas", "license", "licence", "licensing",
      "subscription", "procurement", "purchase", "purchased", "rfp", "demo", "demos",
      "pricing", "per seat", "sales team", "contract with", "signed with", "renewal",
      "implementation partner", "onboarding fee"
    ],
    "min_hits": 3,
    "dominance_ratio": 2.0
  },

  "factors": {
    "_rule": "Deductive decision-factor dictionaries (dictionary-based content analysis: Krippendorff 2018; Grimmer & Stewart 2013). Sources below are SUGGESTIONS drawn from canonical literature - read and confirm each before citing. Salience = share of threads mentioning the factor (reported per tier); tone = mean VADER compound of sentences mentioning it. BEFORE freezing this list, run the step-B cross-check: review high-frequency uncovered terms in term_discovery.csv and add any missing factor the discourse surfaces.",
    "cost_roi": {
      "label": "Cost / ROI / TCO",
      "suggested_source": "Williamson (1985) transaction-cost economics; Ellram (1995) total cost of ownership; Daneshgar et al. (2013)",
      "terms": ["cost", "costs", "costly", "pricing", "price", "prices", "budget", "budgets", "roi", "expensive", "cheap", "cheaper", "fee", "fees", "tco", "total cost of ownership", "payback", "per seat", "per user", "business case", "break even", "breakeven", "value", "value for money", "cost effective", "cost efficient", "expense", "expenses", "depreciation", "amortization", "amortisation", "capex", "opex", "capital expenditure", "operating expense", "subscription", "subscriptions", "subscribe", "recurring cost", "recurring costs", "recurring fee", "recurring fees", "monthly fee", "monthly fees", "annual fee", "annual fees", "yearly fee", "yearly fees", "billing", "invoice", "invoices", "contract value"]
    },
    "integration": {
      "label": "Integration with existing stack",
      "suggested_source": "Daneshgar et al. (2013); Lacity & Hirschheim (1993)",
      "terms": ["integration", "integrations", "integrate", "integrates", "integrated", "api", "apis", "sso", "interoperab*", "connector", "connectors", "plug into", "works with", "sync", "syncs", "embed", "embedded", "tech stack", "current stack", "existing stack", "existing systems", "legacy system", "legacy systems", "current tools", "existing tools", "current setup", "existing infrastructure", "legacy"]
    },
    "security_privacy_compliance": {
      "label": "Security / privacy / regulatory compliance",
      "suggested_source": "ABA Model Rule 1.6 (confidentiality); ILTA Technology Survey; GDPR literature",
      "terms": ["security", "secure", "privacy", "gdpr", "data protection", "confidential*", "compliance", "compliant", "soc 2", "soc2", "iso 27001", "breach", "infosec", "information security", "audit", "on prem*", "sovereignty", "data residency"]
    },
    "lockin_dependency": {
      "label": "Vendor lock-in / dependency risk",
      "suggested_source": "Shapiro & Varian (1999) switching costs; thesis §4.3 dependency-risk concept",
      "terms": ["lock in", "lockin", "locked in", "dependency", "dependent", "dependence", "vendor lock", "migration", "migrate", "exit strategy", "switching cost*", "stuck with", "hostage", "price increase", "raise prices", "raised prices", "offboarding fee", "exit fee", "too embedded", "deeply embedded", "get off boarded", "host our data", "data is hosted"]
    },
    "control_customization_ip": {
      "label": "Control / customization / IP ownership",
      "suggested_source": "Lacity & Hirschheim (1993); Barney (1991) resource-based view",
      "terms": ["control", "customiz*", "customis*", "custom", "bespoke", "tailor*", "flexib*", "ownership", "ip rights", "intellectual property", "own the code", "own the ip", "source code", "open source", "proprietary", "off the shelf", "off-the-shelf", "plug and play"]
    },
    "usability_adoption": {
      "label": "Usability / adoption",
      "suggested_source": "Davis (1989) Technology Acceptance Model",
      "terms": ["ux", "ui", "usability", "user friendly", "intuitive", "adoption", "adopt", "training", "learning curve", "onboarding", "clunky", "easy to use", "user experience"]
    },
    "maintenance_support": {
      "label": "Maintenance burden / vendor support",
      "suggested_source": "Daneshgar et al. (2013); software maintenance economics literature",
      "terms": ["maintenance", "maintain*", "technical debt", "bug", "bugs", "break*", "reliab*", "uptime", "downtime", "outage", "customer support", "support team", "upkeep", "who maintains", "keep it updated", "patches"]
    },
    "time_to_value": {
      "label": "Time to market / speed of deployment",
      "suggested_source": "Daneshgar et al. (2013)",
      "terms": ["time to market", "timeline", "deadline", "implementation time", "deploy*", "rollout", "roll out", "quick win", "mvp", "proof of concept", "poc", "months to build", "weeks to build", "faster to", "quicker to", "time consuming", "time constraints", "no time", "short on time", "time pressure", "takes time", "save time", "saves time", "saving time"]
    },
    "trust_vendor_relationship": {
      "label": "Trust / vendor relationship / organizational change readiness",
      "suggested_source": "Morgan & Hunt (1994) commitment-trust theory",
      "terms": ["trust", "trustworthy", "distrust", "reputation", "references", "reviews", "case studies", "sales team", "salespeople", "relationship", "credib*", "track record", "change culture", "change management", "resistant to change", "change averse", "tech savvy", "digital transformation", "leadership buy in", "favorite vendor", "favourite vendor", "preferred vendor", "existing relationship", "long standing relationship", "board likes", "management likes"]
    },
    "team_expertise": {
      "label": "Team composition & in-house expertise",
      "suggested_source": "Barney (1991) resource-based view; vibe-coding claims (thesis §4.1)",
      "terms": ["developer", "developers", "engineer", "engineers", "engineering team", "technical team", "it team", "it department", "in house expertise", "in house talent", "existing team", "existing engineers", "non technical", "nontechnical", "no code", "low code", "vibe coding", "vibe coded", "skills", "skillset", "expertise", "capability", "capabilities", "upskill", "upskilling"]
    },
    "headcount_impact": {
      "label": "Impact on headcount / staffing levels",
      "suggested_source": "TODO - verify against workforce-automation literature (e.g. Acemoglu & Restrepo on automation and labor demand)",
      "terms": ["headcount", "hire", "hiring", "new hire", "layoff", "layoffs", "reduce headcount", "reducing headcount", "replace staff", "cut staff", "cut jobs", "fewer people", "job cuts", "downsizing", "outsource", "outsourcing", "eliminate positions", "eliminate roles"]
    },
    "professional_risk_accuracy": {
      "label": "Professional risk / accuracy / hallucination",
      "suggested_source": "Dahl, Magesh, Suzgun & Ho (2024) 'Large Legal Fictions', J. Legal Analysis",
      "terms": ["risk", "risks", "risky", "liab*", "malpractice", "ethic*", "professional responsibility", "hallucinat*", "accuracy", "accurate", "inaccurate", "wrong answer", "wrong citation", "fake case", "sanction*", "verify", "verification", "risk appetite", "risk tolerance", "risk averse"]
    },
    "commercialization_potential": {
      "label": "Commercialization potential of the built solution",
      "suggested_source": "TODO - verify against internal-venture/spin-off literature (e.g. Chesbrough 2003 open innovation)",
      "terms": ["commercializ*", "commercialis*", "monetiz*", "monetis*", "sell it", "sell the tool", "spin off", "spin out", "productiz*", "productis*", "resell", "turn into a product", "revenue stream", "sell to other firms", "white label", "white-label"]
    },
    "market_trend_following": {
      "label": "Market trend-following / competitive positioning",
      "suggested_source": "DiMaggio & Powell (1983) institutional isomorphism (mimetic pressure)",
      "terms": ["competitive advantage", "competitor", "competitors", "market trend*", "trending", "keep up with", "keeping up with", "falling behind", "behind the curve", "industry standard", "everyone is using", "fomo", "first mover", "early adopter", "cutting edge", "state of the art", "stay ahead", "stay competitive"]
    },
    "company_characteristics": {
      "label": "Company / legal department characteristics (scale, industry, expertise)",
      "suggested_source": "TODO - verify against firm-size/IT-adoption contingency literature (e.g. Thong 1999)",
      "terms": ["small firm", "large firm", "big firm", "boutique", "solo practitioner", "sole practitioner", "midsize", "mid size", "enterprise", "small business", "large company", "company size", "global firm", "regional firm", "industry", "sector", "practice area"]
    },
    "matter_complexity": {
      "label": "Complexity of the matter / requirement flexibility",
      "suggested_source": "Goodhue & Thompson (1995) task-technology fit",
      "terms": ["complex", "complexity", "complicated", "simple", "simplicity", "requirements", "flexible requirements", "changing requirements", "one size fits all", "unique needs", "unique requirements", "niche use case", "specific needs", "ambiguous requirements", "unclear requirements"]
    }
  },

