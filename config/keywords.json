  "sentiment": {
    "_rule": "The ONLY sentiment measurement in the pipeline: mean VADER compound (Hutto & Gilbert 2014) of exactly those sentences in TIER-1 threads that contain a past-decision marker AND a first-person marker. This captures the tone with which posters describe decisions they actually took ('we bought Clio and regret it') and excludes hypotheticals and advice to third parties ('you should buy...'). Both lists below are the complete, auditable measurement instrument (dictionary-based content analysis: Krippendorff 2018; Grimmer & Stewart 2013).",
    "past_decision_markers": [
      "we built", "i built", "we bought", "i bought", "we went with", "i went with",
      "we chose", "i chose", "we implemented", "i implemented",
      "we signed with", "i signed with", "ended up", "switched to",
      "migrated to", "rolled out"
    ],
    "first_person_markers": ["we", "our", "i"]
  },

  "terms": {
    "_rule": "Settings for the stemmed term counts (step3e) and the term_discovery.csv factor-gap table: standard English stop list plus the extras below, URL fragments stripped, word variants folded by Porter stemming.",
    "min_count": 5,
    "min_token_len": 3,
    "extra_stopwords": [
      "im", "ive", "id", "ill", "dont", "cant", "wont", "didnt", "doesnt", "isnt",
      "arent", "wasnt", "werent", "havent", "hasnt", "youre", "youve", "youll",
