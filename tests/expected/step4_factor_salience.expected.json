  "non_empty_columns": ["factor", "label"],
  "numeric_ranges": {
    "n_threads_decision": {"min": 0},
    "pct_decision_threads": {"min": 0, "max": 100},
    "tone_decision": {"min": -1, "max": 1, "allow_empty": true},
    "n_threads_discourse": {"min": 0},
    "pct_discourse_threads": {"min": 0, "max": 100},
    "tone_discourse": {"min": -1, "max": 1, "allow_empty": true},
    "n_threads_all": {"min": 1},
    "pct_all_threads": {"min": 0, "max": 100},
    "total_mentions": {"min": 1},
    "tone_all": {"min": -1, "max": 1, "allow_empty": true}
  }
}
